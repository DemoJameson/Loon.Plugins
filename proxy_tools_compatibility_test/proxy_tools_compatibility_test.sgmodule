#!name=Proxy Tools Compatibility Test
#!desc=访问 https://m.163.com 输出当前 iOS 代理工具脚本环境兼容性测试结果
#!homepage=https://github.com/DemoJameson/Loon.Plugins
#!author=DemoJameson

[Script]
Proxy Tools Compatibility Test = type=http-response, pattern=^https:\/\/m\.163\.com(?:\/|\?.*)?$, requires-body=1, max-size=0, timeout=10, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/proxy_tools_compatibility_test/proxy_tools_compatibility_test.js

[MITM]
hostname = %APPEND% m.163.com
