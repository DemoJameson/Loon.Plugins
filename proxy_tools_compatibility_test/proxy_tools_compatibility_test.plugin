[Script]
http-response ^https:\/\/m\.163\.com(?:\/|\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/proxy_tools_compatibility_test/proxy_tools_compatibility_test.js, requires-body=true, timeout=10, tag=Proxy Tools Compatibility Test

[MITM]
hostname = m.163.com
