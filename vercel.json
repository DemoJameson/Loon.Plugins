{
    "rewrites": [
        {
            "source": "/admin",
            "destination": "/admin.html"
        },
        {
            "source": "/admin/",
            "destination": "/admin.html"
        }
    ],
    "functions": {
        "api/redirect.js": {
            "maxDuration": 10
        },
        "api/trakt/translations.js": {
            "maxDuration": 30
        }
    },
    "ignoreCommand": "git diff --quiet HEAD^ HEAD -- api/ public/ vercel.json"
}
