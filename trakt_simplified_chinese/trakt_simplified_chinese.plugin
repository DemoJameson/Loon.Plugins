#!name=优化Trakt简体中文体验
#!desc=首页翻译为中文，详情页优先使用简体中文
#!icon=https://app.trakt.tv/pwa/android/icon_192.png
#!homepage=https://github.com/DemoJameson/Loon.Plugins
#!openUrl=https://apps.apple.com/app/id1514873602
#!author=DemoJameson

[Argument]
latestHistoryEpisodeOnly = switch, "true", tag=历史剧集类别只展示最新一集, desc=启用后会将 history/episodes 请求的 limit 提升到 1000，并在响应中同一个剧集只保留集序最新的一集数据
backendBaseUrl = input, "https://loon-plugins.demojameson.de5.net", tag=翻译缓存API, desc=填写你部署的 Vercel 项目 URL

[Script]
# 拦截 users/settings，修改 VIP 和广告显示状态
http-response ^https:\/\/apiz\.trakt\.tv\/users\/settings(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=10, argument=[{backendBaseUrl}], tag=Trakt User Settings
# 拦截 translations/zh 接口，按 zh-CN 优先级排序
http-response ^https:\/\/apiz\.trakt\.tv\/.+\/translations\/zh(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=10, argument=[{backendBaseUrl}], tag=Trakt Translations
# 拦截 up_next_nitro，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/sync\/progress\/up_next_nitro(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Up Next
# 拦截 playback/movies，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/sync\/playback\/movies(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Playback Movies
# 拦截 watchlist/shows，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/me\/watchlist\/shows\/released\/desc(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Watchlist Shows
# 拦截 watchlist/movies，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/me\/watchlist\/movies\/released\/desc(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Watchlist Movies
# 拦截 calendars/my/shows，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/calendars\/my\/shows\/\d{4}-\d{2}-\d{2}\/\d+(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Calendar Shows
# 拦截 calendars/my/movies，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/calendars\/my\/movies\/\d{4}-\d{2}-\d{2}\/\d+(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Calendar Movies
# 拦截 history，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/history\/?(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt History
# 拦截 history/episodes 请求，放大 limit
http-request ^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/history\/episodes\/?(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, argument=[{latestHistoryEpisodeOnly},{backendBaseUrl}], tag=Trakt History Episodes Request
# 拦截 history/episodes 响应，按剧集只保留最新一条
http-response ^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/history\/episodes(?:\/\d+)?\/?(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{latestHistoryEpisodeOnly},{backendBaseUrl}], tag=Trakt History Episodes
# 拦截 history/movies，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/history\/movies\/?(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt History Movies
# 拦截 collection/media，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/collection\/media(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Collection Media
# 拦截 following/activities，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/me\/following\/activities(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Following Activities
# 拦截 list/items，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/lists\/\d+\/items(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt List Items
# 拦截公共 list/items，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/lists\/\d+\/items(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Public List Items
# 拦截 favorites，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/favorites(?:\/(?:shows|movies))?\/?(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Favorites
# 拦截 media/trending，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/media\/trending(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Media Trending
# 拦截 media/recommendations，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/media\/recommendations(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Media Recommendations
# 拦截 media/anticipated，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/media\/anticipated(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Media Anticipated
# 拦截 media/popular/next，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/media\/popular\/next(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Media Popular Next
# 拦截 watchlist，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/me\/watchlist(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Watchlist
# 拦截 watchlist/shows，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/me\/watchlist\/shows(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Watchlist Shows Flat
# 拦截 watchlist/movies，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/users\/me\/watchlist\/movies(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Watchlist Movies Flat
# 拦截带季号的请求，记录当前浏览季
http-request ^https:\/\/apiz\.trakt\.tv\/shows\/[^\/]+\/seasons\/\d+(?:\/.*|\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, argument=[{backendBaseUrl}], tag=Trakt Current Season Request
# 拦截季列表，批量获取简体中文信息
http-response ^https:\/\/apiz\.trakt\.tv\/shows\/[^\/]+\/seasons(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Seasons List
# 拦截 shows 详情
http-response ^https:\/\/apiz\.trakt\.tv\/shows\/[^\/]+(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Show Detail
# 拦截 movies 详情
http-response ^https:\/\/apiz\.trakt\.tv\/movies\/[^\/]+(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Movie Detail
# 拦截 episodes 详情
http-response ^https:\/\/apiz\.trakt\.tv\/shows\/[^\/]+\/seasons\/\d+\/episodes\/\d+(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=20, argument=[{backendBaseUrl}], tag=Trakt Episode Detail

[MITM]
hostname = apiz.trakt.tv
