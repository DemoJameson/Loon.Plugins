#!name=优化Trakt简体中文体验
#!desc=Trakt App各页面从英文改为简体中文；历史页面剧集类别只展示最新的一集，方便以电视剧为单位查看；Trakt 和 Sofa Time 的影片详情页添加 EplayerX、Forward、Infuse 跳转按钮；部分兼容其它使用了 Trakt API 的应用。
#!icon=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/images/trakt.webp
#!homepage=https://github.com/DemoJameson/Loon.Plugins
#!openUrl=https://apps.apple.com/app/id1514873602
#!author=DemoJameson

[Argument]
latestHistoryEpisodeOnly = switch, "true", tag=历史剧集类别只展示最新一集, desc=启用后会将历史页面电视剧类别的已观看记录按电视剧合并
commentTranslationEnabled = switch, "true", tag=翻译评论, desc=启用后会翻译评论，并按评论 id 缓存到本地
eplayerxEnabled = switch, "true", tag=EplayerX 跳转按钮, desc=启用后在 Trakt Watchnow 和 Sofa Time 中注入 EplayerX 跳转按钮
forwardEnabled = switch, "true", tag=Forward 跳转按钮, desc=启用后在 Trakt Watchnow 和 Sofa Time 中注入 Forward 跳转按钮
infuseEnabled = switch, "true", tag=Infuse 跳转按钮, desc=启用后在 Trakt Watchnow 和 Sofa Time 中注入 Infuse 跳转按钮
useShortcutsJumpEnabled = switch, "false", tag=借助快捷指令跳转, desc=启用后播放器跳转链接改为通过快捷指令打开 DeepLink，用于规避弹框确认，Safari浏览器需处于非无痕模式，配置快捷指令 https://www.icloud.com/shortcuts/9238bef05b144159a4351c2fa9e2570d
backendBaseUrl = input, "https://loon-plugins.demojameson.de5.net", tag=翻译缓存API, desc=填写你部署的 Vercel 项目 URL

[Script]
# 手动清理本地缓存脚本
cron "0 0 1 1 1" script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese_clear_cache.js, timeout=10, enable=false, tag=手动清理本地缓存脚本
# 处理播放器 deeplink 跳转
http-request ^https:\/\/loon-plugins\.demojameson\.de5\.net\/api\/redirect\?.*$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{eplayerxEnabled},{forwardEnabled},{infuseEnabled},{useShortcutsJumpEnabled},{backendBaseUrl}], tag=Direct Redirect
# 处理 TMDB logo 跳转
http-request ^https:\/\/image\.tmdb\.org\/t\/p\/w342\/[a-z0-9_-]+_logo\.webp(?:\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{eplayerxEnabled},{forwardEnabled},{infuseEnabled},{useShortcutsJumpEnabled},{backendBaseUrl}], tag=TMDB Logo Redirect
# 拦截 sync/history/episodes 请求，放大 limit
http-request ^https:\/\/apiz?\.trakt\.tv\/sync\/history\/episodes\/?(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{useShortcutsJumpEnabled},{backendBaseUrl}], tag=Trakt Sync History Episodes Request
# 拦截 history/episodes 请求，放大 limit
http-request ^https:\/\/apiz?\.trakt\.tv\/users\/[^\/]+?\/history\/episodes\/?(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{useShortcutsJumpEnabled},{backendBaseUrl}], tag=Trakt History Episodes Request
# 拦截 Rippple 的 history 请求，确保 limit 至少为 100
http-request ^https:\/\/apiz?\.trakt\.tv\/users\/[^\/]+?\/history\/?(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{useShortcutsJumpEnabled},{backendBaseUrl}], tag=Trakt Rippple History Request
# 拦截带季号的请求，记录当前浏览季
http-request ^https:\/\/apiz?\.trakt\.tv\/shows\/[^\/]+\/seasons\/\d+(?:\/.*|\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, timeout=10, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{useShortcutsJumpEnabled},{backendBaseUrl}], tag=Trakt Current Season Request
# 统一拦截 Trakt 响应，由脚本内部分流处理
http-response ^https:\/\/apiz?\.trakt\.tv\/.*$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=40, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{eplayerxEnabled},{forwardEnabled},{infuseEnabled},{useShortcutsJumpEnabled},{backendBaseUrl}], tag=Trakt Response Router
# 仅拦截 Sofa Time 的 TMDB provider 列表，注入播放器
http-response ^https:\/\/api\.(?:themoviedb|tmdb)\.org\/3\/watch\/providers\/(?:movie|tv)(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=40, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{useShortcutsJumpEnabled},{backendBaseUrl}], tag=TMDB Provider Catalog
# 仅拦截 Sofa Time 的 streaming-availability shows 详情，注入播放器
http-response ^https:\/\/streaming-availability\.p\.rapidapi\.com\/shows\/tt\d+(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=40, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{eplayerxEnabled},{forwardEnabled},{infuseEnabled},{useShortcutsJumpEnabled},{backendBaseUrl}], tag=Sofa Time Streaming Availability
# 仅拦截 Sofa Time 的 streaming-availability 国家服务列表，注入播放器
http-response ^https:\/\/streaming-availability\.p\.rapidapi\.com\/countries\/[a-z]{2}(\?.*)?$ script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js, requires-body=true, timeout=40, argument=[{latestHistoryEpisodeOnly},{commentTranslationEnabled},{useShortcutsJumpEnabled},{backendBaseUrl}], tag=Sofa Time Country Services

[MITM]
hostname = apiz.trakt.tv, api.trakt.tv, api.themoviedb.org, image.tmdb.org, streaming-availability.p.rapidapi.com, loon-plugins.demojameson.de5.net



