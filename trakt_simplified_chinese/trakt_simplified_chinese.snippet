#!name=优化Trakt简体中文体验
#!desc=翻译Trakt App首页和各种列表，并且优先使用简体中文；历史页面剧集类别只展示最新的一集，方便查看看过什么电视剧；影片详情页面添加EplayerX、Forward、Infuse的跳转按钮
#!icon=https://app.trakt.tv/pwa/android/icon_192.png
#!homepage=https://github.com/DemoJameson/Loon.Plugins
#!author=DemoJameson

[rewrite_local]
# 拦截 users/settings，修改 VIP 和广告显示状态
^https:\/\/apiz\.trakt\.tv\/users\/settings(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 translations/zh 接口，按 zh-CN 优先级排序
^https:\/\/apiz\.trakt\.tv\/.+\/translations\/zh(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 up_next_nitro，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/sync\/progress\/up_next_nitro(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 playback/movies，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/sync\/playback\/movies(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 watchlist/shows，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/me\/watchlist\/shows\/released\/desc(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 watchlist/movies，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/me\/watchlist\/movies\/released\/desc(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 calendars/my/shows，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/calendars\/my\/shows\/\d{4}-\d{2}-\d{2}\/\d+(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 calendars/my/movies，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/calendars\/my\/movies\/\d{4}-\d{2}-\d{2}\/\d+(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 history，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/history\/?(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 history/episodes 请求，放大 limit
^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/history\/episodes\/?(\?.*)?$ url script-request-header https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 history/episodes 响应，按剧集只保留最新一条
^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/history\/episodes(?:\/\d+)?\/?(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 history/movies，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/history\/movies\/?(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 collection/media，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/collection\/media(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 following/activities，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/me\/following\/activities(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 list/items，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/lists\/\d+\/items(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截公共 list/items，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/lists\/\d+\/items(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 favorites，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/favorites(?:\/(?:shows|movies))?\/?(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 media/trending，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/media\/trending(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 media/recommendations，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/media\/recommendations(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 media/anticipated，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/media\/anticipated(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 media/popular/next，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/media\/popular\/next(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 watchlist，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/me\/watchlist(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 watchlist/shows，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/me\/watchlist\/shows(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 watchlist/movies，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/users\/me\/watchlist\/movies(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截带季号的请求，记录当前浏览季
^https:\/\/apiz\.trakt\.tv\/shows\/[^\/]+\/seasons\/\d+(?:\/.*|\?.*)?$ url script-request-header https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截季列表，批量获取简体中文信息
^https:\/\/apiz\.trakt\.tv\/shows\/[^\/]+\/seasons(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 shows 详情
^https:\/\/apiz\.trakt\.tv\/shows\/[^\/]+(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 movies 详情
^https:\/\/apiz\.trakt\.tv\/movies\/[^\/]+(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 watchnow/sources，注入 Infuse 和 Forward 来源
^https:\/\/apiz\.trakt\.tv\/watchnow\/sources(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 movie/show/episode watchnow，注入 Infuse 和 Forward 跳转链接
^https:\/\/apiz\.trakt\.tv\/(?:movies|shows|episodes)\/[^\/]+\/watchnow(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 episodes 详情
^https:\/\/apiz\.trakt\.tv\/shows\/[^\/]+\/seasons\/\d+\/episodes\/\d+(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 month in review
^https:\/\/apiz\.trakt\.tv\/users\/[^\/]+?\/mir(\?.*)?$ url script-response-body https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js

[mitm]
hostname = apiz.trakt.tv
