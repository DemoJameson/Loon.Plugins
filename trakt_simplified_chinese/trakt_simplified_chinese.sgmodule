#!name=优化Trakt简体中文体验
#!desc=翻译Trakt App首页和各种列表，并且优先使用简体中文；历史页面剧集类别只展示最新的一集；Trakt 和 Sofa Time 的影片详情页添加 EplayerX、Forward、Infuse 跳转按钮
#!icon=https://app.trakt.tv/pwa/android/icon_192.png
#!homepage=https://github.com/DemoJameson/Loon.Plugins
#!author=DemoJameson
#!arguments=latestHistoryEpisodeOnly:"true", commentTranslationEnabled:"true", eplayerxEnabled:"true", forwardEnabled:"true", infuseEnabled:"true", useShortcutsJumpEnabled:"false", backendBaseUrl:"https://loon-plugins.demojameson.de5.net"
#!arguments-desc=latestHistoryEpisodeOnly: 是否只保留历史剧集分类中的最新一集，作用于 history/episodes 和 sync/history/episodes，填入 true 或 false。\ncommentTranslationEnabled: 是否翻译评论，填入 true 或 false。\neplayerxEnabled: 是否注入 EplayerX 跳转按钮，填入 true 或 false。\nforwardEnabled: 是否注入 Forward 跳转按钮，填入 true 或 false。\ninfuseEnabled: 是否注入 Infuse 跳转按钮，填入 true 或 false。\nuseShortcutsJumpEnabled: 是否通过快捷指令打开 DeepLink，用于规避弹框确认，Safari浏览器需处于非无痕模式，填入 true 或 false。\nbackendBaseUrl: 翻译缓存 API 地址，填入你部署的 Vercel 项目 URL。

#借助快捷指令跳转选项的配套快捷指令: https://www.icloud.com/shortcuts/9238bef05b144159a4351c2fa9e2570d

[Script]
# 处理播放器 deeplink 跳转
Direct Redirect = type=http-request, pattern=^https:\/\/loon-plugins\.demojameson\.de5\.net\/api\/redirect\?.*$, timeout=10, argument={{{latestHistoryEpisodeOnly}}},{{{commentTranslationEnabled}}},{{{eplayerxEnabled}}},{{{forwardEnabled}}},{{{infuseEnabled}}},{{{useShortcutsJumpEnabled}}},{{{backendBaseUrl}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 处理 TMDB logo 跳转
TMDB Logo Redirect = type=http-request, pattern=^https:\/\/image\.tmdb\.org\/t\/p\/w342\/[a-z0-9_-]+_logo\.webp(?:\?.*)?$, timeout=10, argument={{{latestHistoryEpisodeOnly}}},{{{commentTranslationEnabled}}},{{{eplayerxEnabled}}},{{{forwardEnabled}}},{{{infuseEnabled}}},{{{useShortcutsJumpEnabled}}},{{{backendBaseUrl}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 sync/history/episodes 请求，放大 limit
Trakt Sync History Episodes Request = type=http-request, pattern=^https:\/\/apiz?\.trakt\.tv\/sync\/history\/episodes\/?(\?.*)?$, timeout=10, argument={{{latestHistoryEpisodeOnly}}},{{{commentTranslationEnabled}}},{{{useShortcutsJumpEnabled}}},{{{backendBaseUrl}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 history/episodes 请求，放大 limit
Trakt History Episodes Request = type=http-request, pattern=^https:\/\/apiz?\.trakt\.tv\/users\/[^\/]+?\/history\/episodes\/?(\?.*)?$, timeout=10, argument={{{latestHistoryEpisodeOnly}}},{{{commentTranslationEnabled}}},{{{useShortcutsJumpEnabled}}},{{{backendBaseUrl}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截 Rippple 的 history 请求，确保 limit 至少为 100
Trakt Rippple History Request = type=http-request, pattern=^https:\/\/apiz?\.trakt\.tv\/users\/[^\/]+?\/history\/?(\?.*)?$, timeout=10, argument={{{latestHistoryEpisodeOnly}}},{{{commentTranslationEnabled}}},{{{useShortcutsJumpEnabled}}},{{{backendBaseUrl}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 拦截带季号的请求，记录当前浏览季
Trakt Current Season Request = type=http-request, pattern=^https:\/\/apiz?\.trakt\.tv\/shows\/[^\/]+\/seasons\/\d+(?:\/.*|\?.*)?$, timeout=10, argument={{{latestHistoryEpisodeOnly}}},{{{commentTranslationEnabled}}},{{{useShortcutsJumpEnabled}}},{{{backendBaseUrl}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 统一拦截 Trakt 响应，由脚本内部分流处理
Trakt Response Router = type=http-response, pattern=^https:\/\/apiz?\.trakt\.tv\/.*$, requires-body=true, max-size=0, timeout=20, argument={{{latestHistoryEpisodeOnly}}},{{{commentTranslationEnabled}}},{{{eplayerxEnabled}}},{{{forwardEnabled}}},{{{infuseEnabled}}},{{{useShortcutsJumpEnabled}}},{{{backendBaseUrl}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 仅拦截 Sofa Time 的 TMDB provider 列表，注入播放器
TMDB Provider Catalog = type=http-response, pattern=^https:\/\/api\.(?:themoviedb|tmdb)\.org\/3\/watch\/providers\/(?:movie|tv)(\?.*)?$, requires-body=true, max-size=0, timeout=20, argument={{{latestHistoryEpisodeOnly}}},{{{commentTranslationEnabled}}},{{{useShortcutsJumpEnabled}}},{{{backendBaseUrl}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 仅拦截 Sofa Time 的 streaming-availability shows 详情，注入播放器
Sofa Time Streaming Availability = type=http-response, pattern=^https:\/\/streaming-availability\.p\.rapidapi\.com\/shows\/tt\d+(\?.*)?$, requires-body=true, max-size=0, timeout=20, argument={{{latestHistoryEpisodeOnly}}},{{{commentTranslationEnabled}}},{{{eplayerxEnabled}}},{{{forwardEnabled}}},{{{infuseEnabled}}},{{{useShortcutsJumpEnabled}}},{{{backendBaseUrl}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js
# 仅拦截 Sofa Time 的 streaming-availability 国家服务列表，注入播放器
Sofa Time Country Services = type=http-response, pattern=^https:\/\/streaming-availability\.p\.rapidapi\.com\/countries\/[a-z]{2}(\?.*)?$, requires-body=true, max-size=0, timeout=20, argument={{{latestHistoryEpisodeOnly}}},{{{commentTranslationEnabled}}},{{{useShortcutsJumpEnabled}}},{{{backendBaseUrl}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/trakt_simplified_chinese/trakt_simplified_chinese.js

[MITM]
hostname = %APPEND% apiz.trakt.tv, api.trakt.tv, api.themoviedb.org, image.tmdb.org, streaming-availability.p.rapidapi.com, loon-plugins.demojameson.de5.net

