#!name=GitHub Raw链接重定向到本地
#!desc=将指定仓库的 raw.githubusercontent.com 请求重定向到本地测试服务，例如把 https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/a.js 转到 http://192.168.50.2:8080/Loon.Plugins/a.js
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/GitHub.png
#!homepage=https://github.com/DemoJameson/Loon.Plugins
#!author=DemoJameson
#!arguments=localBaseUrl:"http://192.168.50.2:8080", repository:"Loon.Plugins"
#!arguments-desc=localBaseUrl: 本地测试服务根地址，不要带结尾斜杠。\nrepository: 仅重定向该仓库的 raw 链接，默认值为 Loon.Plugins。

[Script]
Github Raw Redirect = type=http-request, pattern=^https:\/\/raw\.githubusercontent\.com\/.*$, timeout=10, argument={{{localBaseUrl}}},{{{repository}}}, script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/main/github_redirect_to_local/github_redirect_to_local.js

[MITM]
hostname = %APPEND% raw.githubusercontent.com
