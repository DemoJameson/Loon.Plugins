#!name=接入TIDB片头片尾
#!desc=拦截Emby接口并注入TheIntroDB的片头片尾数据。需要自行添加Emby的域名到MitM。
#!icon=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/dev/tidb_into_emby/icon.png
#!homepage=https://github.com/DemoJameson/Loon.Plugins
#!openUrl=https://theintrodb.org/docs
#!author=DemoJameson

[Argument]
tidb_override_existing=switch, "false", tag=覆盖Emby原有片头片尾, desc=是否覆盖Emby原有的片头片尾标记
tidb_notify_rate_limit=switch, "true", tag=TIDB限流通知, desc=TheIntroDB限流时是否弹出通知
tidb_max_episodes=input, "5", tag=每次最多请求集数, desc=单次最多向TheIntroDB请求的集数上限
tidb_api_key=input, "", tag=TIDB API Key, desc=TheIntroDB API密钥
tidb_cache_api=input, "https://loon-plugins.demojameson.de5.net", tag=TIDB缓存API, desc=填写自建缓存服务地址，不填则使用默认服务端
tidb_ignore_players=input, "Infuse, Vidora", tag=忽略已集成TIDB的播放器, desc=如果请求User-Agent以这些值开头则不做任何处理，多个值用逗号分隔

[Script]
http-response ^https?:\/\/.+\/emby\/(Shows\/.+\/Episodes|Users\/.+\/Items\/.+|Items\/.+\/PlaybackInfo) script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/dev/tidb_into_emby/tidb_into_emby.js, requires-body=true, timeout=10, argument=[{tidb_override_existing},{tidb_notify_rate_limit},{tidb_max_episodes},{tidb_api_key},{tidb_cache_api},{tidb_ignore_players}], tag=Emby相关接口
cron "0 0 30 2 *" script-path=https://raw.githubusercontent.com/DemoJameson/Loon.Plugins/dev/tidb_into_emby/tidb_into_emby_clear_cache.js, tag=TIDB本地缓存清除脚本, enable=true
